# ---- Raw / large processed data (too large for git; see README to download) ----
data/raw/telecom/*
data/raw/grid/*
data/processed/*
downloads/
!data/raw/telecom/.gitkeep
!data/raw/grid/.gitkeep
!data/processed/.gitkeep

# Keep the small reproducibility sample (3 target-area series) under version control.
!data/sample/

# Generated figures, tables and experiment logs ARE kept in the repo so the
# report renders and results are visible without re-running the 20 GB pipeline.

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# ---- Models / checkpoints ----
*.keras
*.h5
*.pkl
models_saved/

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.vscode/
.idea/
